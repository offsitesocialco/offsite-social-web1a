---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Offsite Social Co." description="Clock out. Join in." />
		<style>
			:root {
				--bg-color: #0f2e26; /* Deep heritage green matching Gamma */
				--text-main: #f5e6d3; /* Cream text */
				--accent: #e08b6c; /* Terracotta */
				--card-bg: rgba(255,255,255,0.05); 
			}
			body {
				background-color: var(--bg-color);
				color: var(--text-main);
				font-family: 'Georgia', 'Times New Roman', serif;
				font-size: 1.15rem; /* Larger base text for readability */
				margin: 0;
				padding: 0;
				line-height: 1.8; /* Extra breathing room between lines */
				-webkit-font-smoothing: antialiased;
			}
			.container {
				max-width: 1000px; /* Slightly wider to accommodate 3 columns */
				margin: 0 auto;
				padding: 4rem 2rem;
			}
			
			/* HERO SECTION */
			.hero {
				text-align: center;
				margin-bottom: 6rem;
			}
			.hero h1 {
				font-size: 4rem;
				letter-spacing: 2px;
				margin-bottom: 0.5rem;
				font-weight: normal;
			}
			.hero h3 {
				font-size: 1.2rem;
				font-family: sans-serif;
				text-transform: uppercase;
				letter-spacing: 3px;
				margin-bottom: 2rem;
				color: var(--text-main);
			}
			.hero p {
				max-width: 800px;
				margin: 0 auto 1.5rem;
			}
			.hero-logo {
				width: 250px;
				height: auto;
				margin: 3rem auto;
				display: block;
			}

			/* BUTTONS */
			.button-group {
				display: flex;
				gap: 1rem;
				justify-content: center;
			}
			.btn {
				padding: 0.8rem 1.8rem;
				text-decoration: none;
				border: 1px solid var(--accent);
				color: var(--text-main);
				font-family: sans-serif;
				text-transform: uppercase;
				font-size: 0.85rem;
				letter-spacing: 1px;
				transition: all 0.2s ease;
			}
			.btn-primary {
				background-color: var(--accent);
				color: #111;
				font-weight: bold;
			}
			.btn:hover {
				opacity: 0.9;
			}

			/* TYPOGRAPHY & TAGS */
			.section-title {
				font-size: 2.8rem;
				border-bottom: 1px solid rgba(245, 230, 211, 0.3);
				padding-bottom: 1rem;
				margin-bottom: 2.5rem;
				font-weight: normal;
				margin-top: 0.5rem;
			}
			.tag {
				background-color: rgba(60, 20, 10, 0.5);
				color: var(--accent);
				padding: 0.2rem 0.5rem;
				font-size: 0.75rem;
				font-family: sans-serif;
				text-transform: uppercase;
				letter-spacing: 1.5px;
			}

			/* GRIDS */
			.launch-grid {
				display: grid;
				grid-template-columns: 1fr 1.2fr 1fr; /* 3 Columns matching Gamma 2 */
				gap: 3rem;
				margin-bottom: 5rem;
			}
			.center-col {
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
			}
			.bartaco-logo {
				width: 100%;
				max-width: 200px;
				margin-bottom: 2rem;
			}
			.grid-3 {
				display: grid;
				grid-template-columns: 1fr 1fr 1fr;
				gap: 1.5rem;
				margin-bottom: 3rem;
			}
			.grid-2 {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: 3rem;
				margin-bottom: 5rem;
			}

			/* CARDS */
			.card {
				background-color: var(--card-bg);
				padding: 2rem;
				border-left: 3px solid var(--accent);
			}
			.card h4 {
				font-size: 1.4rem;
				margin-top: 0;
				margin-bottom: 1rem;
				font-weight: normal;
			}
			.card-blue {
				border-left: 3px solid #1e3a8a;
				background-color: rgba(30, 58, 138, 0.2);
			}

			/* FOOTER */
			.footer-section {
				margin-top: 6rem;
				border-top: 1px solid rgba(245, 230, 211, 0.3);
				padding-top: 4rem;
				display: grid;
				grid-template-columns: 2fr 1fr;
				gap: 4rem;
			}
			.legal {
				font-size: 0.9rem;
				opacity: 0.7;
				margin-top: 5rem;
				border-left: 2px solid var(--accent);
				padding-left: 1rem;
			}

			/* MOBILE RESPONSIVE */
			@media (max-width: 900px) {
				.launch-grid {
					grid-template-columns: 1fr;
				}
				.center-col {
					order: -1; /* Puts the logo and button at the top on mobile */
					margin-bottom: 2rem;
				}
				.grid-2, .grid-3, .footer-section {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<main class="container">
			
			<!-- HERO SECTION (Matches Gamma 1) -->
			<section class="hero">
				<h1>OFFSITE SOCIAL CO.</h1>
				<h3>Clock Out. Join In.</h3>
				<p>An independent community initiative bridging the gap between the desk and the block. Built for remote workers who want genuine neighborhood connection. Not another networking event. Not another coupon book.</p>
				<p><strong>A genuine offline ritual.</strong></p>
				
				<!-- Placeholder for the circular compass logo -->
				<img src="/compass-logo.png" alt="Offsite Social Co. Compass" class="hero-logo" onerror="this.style.display='none';">
				
				<div class="button-group">
					<a href="#join" class="btn btn-primary">Join The Collective</a>
					<a href="/about" class="btn">Learn More</a>
				</div>
			</section>

			<!-- LAUNCH PARTY (Matches Gamma 2) -->
			<section>
				<span class="tag">Launch</span>
				<h2 class="section-title">The LoHi Launch Party</h2>
				
				<div class="launch-grid">
					<!-- Left Column -->
					<div>
						<p><strong>Thursday, June 4th</strong></p>
						<p>4:30 PM – 6:30 PM<br>bartaco LoHi</p>
						<p>Join us for an evening of genuine connection on the block.</p>
						<p>Agua frescas, and appetizer trios (chips, salsa & guac) are on the house, along side $8 featured margs all evening long.</p>
						<div class="card" style="margin-top: 2rem; padding: 1.5rem;">
							<p style="margin:0; font-size: 0.95rem;">Space for the Launch Party is limited. Secure your spot by June 2.</p>
						</div>
					</div>
					
					<!-- Center Column (Logo + Button) -->
					<div class="center-col">
						<!-- Placeholder for bartaco logo -->
						<img src="/bartaco-logo.png" alt="bartaco" class="bartaco-logo" onerror="this.style.display='none';">
						<a href="https://buttondown.email/offsitesocialco" class="btn btn-primary">Secure Your Spot</a>
					</div>

					<!-- Right Column -->
					<div>
						<p>This is not a networking event. There are no name tags, no elevator pitches, no panels. It is a Thursday afternoon at a good bar with the people who live and work on the same blocks you do.</p>
						<p>The LoHi Pilot is the first proof of a simple premise: that remote workers in the same neighborhood have more in common than proximity alone, and that a shared table and an unhurried hour is enough to begin building something durable.</p>
						<p style="border-left: 2px solid var(--accent); padding-left: 1rem; margin-top: 2rem;">Clock out. Join in.</p>
					</div>
				</div>
			</section>

			<!-- TUESDAY ANCHOR (Matches Gamma 3) -->
			<section>
				<span class="tag">The Weekly Routine</span>
				<h2 class="section-title">The Tuesday Anchor</h2>
				<p style="margin-bottom: 2rem;">Community is not a one-off meetup. It is a weekly rhythm you can build a workday around.</p>
				<p style="margin-bottom: 2rem;"><strong>Starting June 9th, every Tuesday from 11:00 AM to 3:00 PM at bartaco LoHi.</strong></p>
				
				<div class="grid-3">
					<div class="card">
						<h4>Show Your Card</h4>
						<p>Present your member card when ordering. No QR code theater. No coupons to save.</p>
					</div>
					<div class="card">
						<h4>Claim Your Tray</h4>
						<p>A complimentary app trio (chips, salsa, guac) on the house with the purchase of a lunch tray.</p>
						<p style="color: var(--accent); font-style: italic; margin-top: 1rem;">$13 value</p>
					</div>
					<div class="card">
						<h4>Live the Block</h4>
						<p>Settle in beside your neighbors. Same hours. Same place. Every single Tuesday.</p>
					</div>
				</div>
				
				<div class="grid-2">
					<div>
						<p>bartaco LoHi is our exclusive Tuesday Lunch Anchor. As the network grows, additional neighborhood partners, each distinct local spots with their own character and craft, will be introduced through recurring drops.</p>
						<p>The anchor is always the same day, the same place, the same unhurried window of time. Build your neighborhood routine.</p>
					</div>
					<div class="card card-blue">
						<p style="margin:0; font-size: 1rem;">New venues and local partnerships will be announced as the network expands. Each addition will reflect the neighborhood.</p>
					</div>
				</div>
			</section>

			<!-- FOOTER / JOIN (Matches Gamma 4) -->
			<section id="join" class="footer-section">
				<div>
					<span class="tag">The Collective</span>
					<h2 class="section-title" style="border:none; padding:0; margin-bottom: 1rem;">Join the Collective</h2>
					<p>Get notified when new neighborhood drops, Tuesday Anchor locations, and local partnerships open up. The Collective is free. There is no algorithm behind it. It is simply a list of people who want to be part of what is being built here, block by block.</p>
					<a href="https://buttondown.email/offsitesocialco" class="btn btn-primary" style="display:inline-block; margin-top:1rem;">Join The Collective</a>
				</div>
				<div>
					<h4 style="border-bottom: 1px solid rgba(245,230,211,0.3); padding-bottom:0.5rem; margin-bottom: 1rem;">Contact</h4>
					<p style="margin:0;"><a href="mailto:offsitesocialco@gmail.com" style="color: var(--accent); text-decoration:none;">offsitesocialco@gmail.com</a></p>
					
					<h4 style="border-bottom: 1px solid rgba(245,230,211,0.3); padding-bottom:0.5rem; margin-top: 2rem; margin-bottom: 1rem;">Instagram</h4>
					<p style="margin:0;">@offsitesocialco</p>
					
					<h4 style="border-bottom: 1px solid rgba(245,230,211,0.3); padding-bottom:0.5rem; margin-top: 2rem; margin-bottom: 1rem;">Operated By</h4>
					<p style="margin:0;">Community Craft, Ltd.</p>
				</div>
			</section>
			
			<div class="legal">
				Offsite Social Co. is an independent project. No venture backing. No growth hacks. Just neighbors.
			</div>
		</main>
	</body>
</html>